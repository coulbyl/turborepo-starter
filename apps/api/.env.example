# ──────────────────────────────────────────────
# Starter API — Environment Variables Template
# Copy to .env and fill in real values.
# Never commit .env — only .env.example.
# ──────────────────────────────────────────────

# ── Server ────────────────────────────────────
PORT=3001
HOST=0.0.0.0
# Allowed CORS origin. Set to the frontend URL in production.
# Defaults to true (all origins) if omitted — restrict in production.
CORS_ORIGIN=http://localhost:3000
AUTH_COOKIE_DOMAIN=localhost
# Public URL of the frontend — used for reset password links in emails.
APP_URL=http://localhost:3000

# ── Auth / MFA ─────────────────────────────────────────────────────────────────
# Random secret used to AES-256-GCM encrypt TOTP secrets stored in the database.
# Generate with: openssl rand -base64 32
# NEVER rotate this in production without decrypting and re-encrypting all TOTP secrets first.
TOTP_APP_SECRET=your_random_32_byte_secret_here

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/starter

# ── Seed admin user (optional) ────────────────
# Used by `pnpm --filter @starter/db db:seed`.
# The seed creates the admin only when SEED_ADMIN_PASSWORD is set.
SEED_ADMIN_EMAIL=admin@starter.local
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_FULL_NAME=Starter Admin
SEED_ADMIN_PASSWORD=

# ── Redis (BullMQ) ────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── SMTP (nodemailer) ─────────────────────────────────────────────────────────
# Set SMTP_ENABLED=true to activate email sending.
# In local dev: use Mailpit (docker-compose) — no real emails sent.
# In production: replace with your SMTP provider (Gmail, Amazon SES, etc.)
SMTP_ENABLED=false

# Local dev (Mailpit): host=localhost, port=1025, no auth
# Production (Gmail):  host=smtp.gmail.com, port=587, secure=false + app password
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false

# Leave empty for Mailpit (no auth). Fill in for real SMTP providers.
SMTP_USER=
SMTP_PASSWORD=

SMTP_FROM=starter@localhost

# ── Logging ───────────────────────────────────────
# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
# Directory for log files (defaults to <cwd>/logs if omitted)
LOG_DIR=./logs
