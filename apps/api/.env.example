# ──────────────────────────────────────────────
# Identis API — Environment Variables Template
# Copy to .env and fill in real values.
# Never commit .env — only .env.example.
# ──────────────────────────────────────────────

# ── Server ────────────────────────────────────
PORT=3001
HOST=0.0.0.0
# Allowed CORS origin. Set to the frontend URL in production.
# Defaults to true (all origins) if omitted — restrict in production.
CORS_ORIGIN=http://localhost:3000
AUTH_COOKIE_DOMAIN=localhost
# Public URL of the frontend — used for reset password links in emails.
APP_URL=http://localhost:3000

# ── Auth / MFA ─────────────────────────────────────────────────────────────────
# Random secret used to AES-256-GCM encrypt TOTP secrets stored in the database.
# Generate with: openssl rand -base64 32
# NEVER rotate this in production without decrypting and re-encrypting all TOTP secrets first.
TOTP_APP_SECRET=your_random_32_byte_secret_here

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/identis

# ── Seed admin user (optional) ────────────────
# Used by `pnpm --filter @identis/db db:seed`.
# The seed creates the admin only when SEED_ADMIN_PASSWORD is set.
SEED_ADMIN_EMAIL=admin@identis.ci
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_FULL_NAME=Identis Admin
SEED_ADMIN_PASSWORD=

# ── Redis (BullMQ) ────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── SMTP (nodemailer) ─────────────────────────────────────────────────────────
# Set SMTP_ENABLED=true to activate email sending.
# In local dev: use Mailpit (docker-compose) — no real emails sent.
# In production: replace with your SMTP provider (Gmail, Amazon SES, etc.)
SMTP_ENABLED=false

# Local dev (Mailpit): host=localhost, port=1025, no auth
# Production (Gmail):  host=smtp.gmail.com, port=587, secure=false + app password
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false

# Leave empty for Mailpit (no auth). Fill in for real SMTP providers.
SMTP_USER=
SMTP_PASSWORD=

SMTP_FROM=noreply@identis.ci

# ── Verification provider ─────────────────────────────────────────────────────
# "fake"  → FakeVerificationProvider (no Smile ID needed, webhook simulé après 2s)
# "smile" → SmileIdProvider (Smile ID credentials requis)
VERIFICATION_PROVIDER=fake

# Résultat simulé par le fake provider : approve | reject | random
FAKE_PROVIDER_OUTCOME=approve

# ── Smile ID ──────────────────────────────────────────────────────────────────
# Obtenir sur portal.usesmileid.com → Settings → API Key
# SMILE_ID_ENV=0 = sandbox (test gratuit), 1 = production
SMILE_ID_PARTNER_ID=
SMILE_ID_API_KEY=
SMILE_ID_ENV=0
# URL publique où Smile ID envoie les résultats async (webhook)
# En local avec fake provider : http://localhost:3001/webhooks/smile
# En production avec Smile ID : URL ngrok ou domaine public
SMILE_ID_CALLBACK_URL=http://localhost:3001/webhooks/smile

# ── Cloudflare R2 (biometric photo storage) ───────────────────────────────────
# Photos CNI + selfie stockées sur R2, chiffrées AES-256, jamais en base.
# Créer un bucket sur dash.cloudflare.com → R2 → Create bucket.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=identis-biometrics

# ── Encryption ────────────────────────────────────────────────────────────────
# Clé 32 octets (hex) pour AES-256 — chiffrement des données biométriques.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ── WhatsApp (Meta Business API) ──────────────────────────────────────────────
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=

# ── Logging ───────────────────────────────────────
# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
# Directory for log files (defaults to <cwd>/logs if omitted)
LOG_DIR=./logs
