# ══════════════════════════════════════════════════════════════════════════════
# Starter — Infrastructure Environment Variables Template
# Copy to .env and fill in real values.
# Never commit .env — only .env.example.
#
# This file drives docker-compose.yml (PostgreSQL + Redis + Mailpit).
# For backend application variables, see apps/api/.env.example.
# ══════════════════════════════════════════════════════════════════════════════


# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Primary database for all application data.

POSTGRES_DB=starter
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production

# Host port mapped to container port 5432.
POSTGRES_PORT=5432


# ── Redis ─────────────────────────────────────────────────────────────────────
# Used by BullMQ for async job queues.

# Host port mapped to container port 6379.
REDIS_PORT=6379


# ── Mailpit (local email testing) ─────────────────────────────────────────────
# Mailpit captures all outgoing emails in local dev — no real emails are sent.
# Web UI: http://localhost:8025  |  SMTP: localhost:1025
# In production, point SMTP_HOST/PORT to your real SMTP provider (Gmail, SES, etc.)

MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
